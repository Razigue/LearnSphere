{
	"$schema": "https://schemas.wp.org/wp/7.1/theme.json",
	"version": 3,
	"customTemplates": [
		{
			"name": "page-no-title",
			"postTypes": [
				"page"
			],
			"title": "Page No Title"
		}
	],
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#FBF4E8",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#282828",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#FCED50",
					"name": "Accent 1",
					"slug": "accent-1"
				},
				{
					"color": "#FAB25D",
					"name": "Accent 2",
					"slug": "accent-2"
				},
				{
					"color": "#A2363D",
					"name": "Accent 3",
					"slug": "accent-3"
				},
				{
					"color": "#524C8D",
					"name": "Accent 4",
					"slug": "accent-4"
				},
				{
					"color": "#F2E8D2",
					"name": "Accent 5",
					"slug": "accent-5"
				},
				{
					"color": "color-mix(in srgb, currentColor 20%, transparent)",
					"name": "Accent 6",
					"slug": "accent-6"
				}
			]
		},
		"layout": {
			"contentSize": "680px",
			"wideSize": "1320px"
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "Card",
					"shadow": "0 1px 3px rgba(40,40,40,0.07), 0 1px 2px rgba(40,40,40,0.06)",
					"slug": "card"
				},
				{
					"name": "Pop",
					"shadow": "0 8px 24px rgba(40,40,40,0.10), 0 3px 8px rgba(40,40,40,0.06)",
					"slug": "pop"
				},
				{
					"name": "Heavy",
					"shadow": "0 20px 56px rgba(40,40,40,0.14), 0 8px 16px rgba(40,40,40,0.08)",
					"slug": "heavy"
				}
			]
		},
		"spacing": {
			"customSpacingSize": true,
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Tiny",
					"size": "8px",
					"slug": "20"
				},
				{
					"name": "X-Small",
					"size": "12px",
					"slug": "30"
				},
				{
					"name": "Small",
					"size": "16px",
					"slug": "40"
				},
				{
					"name": "Regular",
					"size": "clamp(16px, 2vw, 24px)",
					"slug": "50"
				},
				{
					"name": "Large",
					"size": "clamp(24px, 4vw, 32px)",
					"slug": "60"
				},
				{
					"name": "X-Large",
					"size": "clamp(32px, 5vw, 48px)",
					"slug": "70"
				},
				{
					"name": "XX-Large",
					"size": "clamp(48px, 8vw, 96px)",
					"slug": "80"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"customFontSize": true,
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Nunito",
							"fontStretch": "normal",
							"fontStyle": "normal",
							"fontWeight": "200 1000",
							"src": [
								"file:./assets/fonts/Nunito/Nunito-VariableFont_wght.ttf"
							]
						},
						{
							"fontFamily": "Nunito",
							"fontStretch": "normal",
							"fontStyle": "italic",
							"fontWeight": "200 1000",
							"src": [
								"file:./assets/fonts/Nunito/Nunito-Italic-VariableFont_wght.ttf"
							]
						}
					],
					"fontFamily": "Nunito, sans-serif",
					"name": "Nunito",
					"slug": "nunito"
				},
				{
					"fontFace": [
						{
							"fontFamily": "Regime Round",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/regime-round/RegimeRound-RegularRound.woff2"
							]
						},
						{
							"fontFamily": "Regime Round",
							"fontStyle": "normal",
							"fontWeight": "500",
							"src": [
								"file:./assets/fonts/regime-round/RegimeRound-MediumRound.woff2"
							]
						},
						{
							"fontFamily": "Regime Round",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/regime-round/RegimeRound-BoldRound.woff2"
							]
						}
					],
					"fontFamily": "\"Regime Round\", sans-serif",
					"name": "Regime Round",
					"slug": "regime-round"
				},
				{
					"fontFamily": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
					"name": "Monospace",
					"slug": "monospace"
				}
			],
			"fontSizes": [
				{
					"fluid": false,
					"name": "Small",
					"size": "0.8125rem",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "1.0625rem",
						"min": "1rem"
					},
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.5rem",
						"min": "1.125rem"
					},
					"name": "Large",
					"size": "1.125rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "3rem",
						"min": "1.75rem"
					},
					"name": "Extra Large",
					"size": "1.75rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "5.5rem",
						"min": "2.75rem"
					},
					"name": "Extra Extra Large",
					"size": "2.75rem",
					"slug": "xx-large"
				}
			],
			"fontStyle": true,
			"fontWeight": true,
			"letterSpacing": true,
			"textDecoration": true,
			"textTransform": true,
			"writingMode": true
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/button": {
				"variations": {
					"outline": {
						"border": {
							"color": "currentColor",
							"width": "1px"
						},
						"css": ".wp-block-button.is-style-outline .wp-block-button__link,.wp-block-button__link.is-style-outline{border-radius:8px;} .wp-block-button__link:not(.has-background):hover{background-color:color-mix(in srgb, var:preset|color|accent-4 12%, transparent);}",
						"spacing": {
							"padding": {
								"bottom": "calc(0.875rem - 1px)",
								"left": "calc(1.375rem - 1px)",
								"right": "calc(1.375rem - 1px)",
								"top": "calc(0.875rem - 1px)"
							}
						}
					}
				}
			},
			"core/buttons": {
				"spacing": {
					"blockGap": {
						"left": "var(--wp--preset--spacing--20)",
						"top": "var(--wp--preset--spacing--40)"
					}
				}
			},
			"core/code": {
				"border": {
					"radius": "8px"
				},
				"color": {
					"background": "var(--wp--preset--color--accent-5)",
					"text": "var(--wp--preset--color--contrast)"
				},
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--40)",
						"left": "var(--wp--preset--spacing--40)",
						"right": "var(--wp--preset--spacing--40)",
						"top": "var(--wp--preset--spacing--40)"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--monospace)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "500",
					"lineHeight": "1.6"
				}
			},
			"core/navigation": {
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nunito)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "700",
					"letterSpacing": "0.08em",
					"textTransform": "uppercase"
				}
			},
			"core/site-title": {
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--regime-round)",
					"fontWeight": "500",
					"letterSpacing": "0"
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"elements": {
			"button": {
				":focus": {
					"outline": {
						"color": "var(--wp--preset--color--accent-4)",
						"offset": "2px"
					}
				},
				":hover": {
					"border": {
						"color": "transparent"
					},
					"color": {
						"background": "var(--wp--preset--color--accent-4)",
						"text": "var(--wp--preset--color--base)"
					}
				},
				"border": {
					"radius": "8px"
				},
				"color": {
					"background": "var(--wp--preset--color--contrast)",
					"text": "var(--wp--preset--color--base)"
				},
				"spacing": {
					"padding": {
						"bottom": "0.875rem",
						"left": "1.375rem",
						"right": "1.375rem",
						"top": "0.875rem"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nunito)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "700",
					"letterSpacing": "0.08em",
					"textTransform": "uppercase"
				}
			},
			"caption": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"lineHeight": "1.4"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"letterSpacing": "0.5px"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "700",
					"letterSpacing": "1.4px",
					"textTransform": "uppercase"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--regime-round)",
					"fontWeight": "400",
					"letterSpacing": "0",
					"lineHeight": "1.02"
				}
			},
			"link": {
				":hover": {
					"typography": {
						"textDecoration": "none"
					}
				},
				"color": {
					"text": "currentColor"
				},
				"typography": {
					"textDecoration": "underline"
				}
			}
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--50)",
			"padding": {
				"left": "var(--wp--preset--spacing--50)",
				"right": "var(--wp--preset--spacing--50)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--nunito)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"fontWeight": "400",
			"letterSpacing": "0",
			"lineHeight": "1.5"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "header",
			"name": "vertical-header",
			"title": "Vertical site header"
		},
		{
			"area": "header",
			"name": "header-large-title",
			"title": "Header with large title"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		},
		{
			"area": "footer",
			"name": "footer-columns",
			"title": "Footer Columns"
		},
		{
			"area": "footer",
			"name": "footer-newsletter",
			"title": "Footer Newsletter"
		},
		{
			"area": "uncategorized",
			"name": "sidebar",
			"title": "Sidebar"
		}
	]
}